{
  "name": "agentmind-cli",
  "version": "0.2.2",
  "description": "A live window into your agent's mind — watch every thought, tool call and reply your coding agent makes, in real time, locally.",
  "license": "MIT",
  "type": "module",
  "private": false,
  "bin": {
    "agentmind-cli": "./bin/cli.js"
  },
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 8088 --host 127.0.0.1",
    "build": "vite build && pnpm build:cli",
    "build:cli": "esbuild src/server/prod-entry.ts --bundle --platform=node --format=esm --target=node20 --outfile=dist/agentmind/cli.mjs --external:node:* --external:undici --external:srvx --external:srvx/node",
    "preview": "vite preview",
    "start": "node dist/agentmind/cli.mjs",
    "typecheck": "tsc --noEmit",
    "smoke": "pnpm build && node scripts/smoke-codex.mjs && node scripts/smoke-launcher.mjs",
    "prepublishOnly": "pnpm build && pnpm typecheck"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@tailwindcss/vite": "^4.1.0",
    "@tanstack/react-router": "^1.167.0",
    "@tanstack/react-start": "^1.167.0",
    "@tanstack/router-plugin": "^1.167.0",
    "@uiw/react-json-view": "2.0.0-alpha.42",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.577.0",
    "open": "^10.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "srvx": "0.11.15",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.1.0",
    "tw-animate-css": "^1.3.6",
    "undici": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "0.27.7",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "bin",
    "dist"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  },
  "packageManager": "pnpm@10.33.2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imsobear/agentmind.git"
  },
  "bugs": {
    "url": "https://github.com/imsobear/agentmind/issues"
  },
  "homepage": "https://github.com/imsobear/agentmind#readme"
}
